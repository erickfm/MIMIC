# MIMIC Discord bot config.
#
# 1. Copy this file to `.env` in the repo root:
#       cp .env.example .env
# 2. Fill in DISCORD_BOT_TOKEN and BOT_SLIPPI_CODE (and optionally override paths).
# 3. Run the bot:
#       python3 tools/discord_bot.py
#
# Defaults below assume `bash setup.sh` has been run at the repo root — it
# places Dolphin under ./emulator/squashfs-root/usr/bin and the ISO at ./melee.iso,
# which is what these defaults point at. If you installed things elsewhere, edit
# the paths.
#
# This file is gitignored. Never commit it — DISCORD_BOT_TOKEN is a secret.

# ---- REQUIRED ----

# From https://discord.com/developers/applications → your app → Bot → Reset Token.
# You MUST also enable "Message Content Intent" under Privileged Gateway Intents
# on the same page, or !play won't work.
DISCORD_BOT_TOKEN=

# The bot's own Slippi direct-connect code (e.g. MIMIC#01). Shown in !info so
# users know what to enter on their side. Must match the `connectCode` field in
# <SLIPPI_HOME>/Slippi/user.json (see below).
BOT_SLIPPI_CODE=MIMIC#01

# ---- SLIPPI LOGIN ----
#
# Dolphin needs a Slippi user.json to log into Slippi Online. The bot looks
# at $SLIPPI_HOME/Slippi/user.json. If that file doesn't exist, the bot will
# synthesize one from the env vars below and write it there automatically.
#
# THREE WAYS to provide credentials, in priority order:
#
#   A) Put the file yourself:
#      mkdir -p ./slippi_home/Slippi
#      cp ~/.config/SlippiOnline/Slippi/user.json ./slippi_home/Slippi/
#
#   B) Paste the whole JSON blob inline (escape any literal `$` as `\$`):
#      SLIPPI_USER_JSON={"uid":"...","connectCode":"MIMIC#01","playKey":"...","displayName":"MIMIC","latestVersion":"3.5.2"}
#
#   C) Individual fields (recommended for .env — no quoting headaches):
#      SLIPPI_UID=...           # from your account's user.json
#      SLIPPI_PLAY_KEY=...      # from your account's user.json
#      SLIPPI_CONNECT_CODE=MIMIC#01        # same as BOT_SLIPPI_CODE above
#      SLIPPI_DISPLAY_NAME=MIMIC
#      SLIPPI_LATEST_VERSION=3.5.2
#
# To get `uid` and `playKey`: create a Slippi account via Slippi Launcher and
# copy them out of the generated user.json:
#   Linux:   ~/.config/SlippiOnline/Slippi/user.json
#   macOS:   ~/Library/Application Support/com.project-slippi.dolphin/netplay/User/Slippi/user.json
#   Windows: %APPDATA%\Slippi Launcher\netplay\User\Slippi\user.json
SLIPPI_HOME=./slippi_home
SLIPPI_UID=
SLIPPI_PLAY_KEY=
SLIPPI_CONNECT_CODE=
SLIPPI_DISPLAY_NAME=
SLIPPI_LATEST_VERSION=

# ---- OPTIONAL (auto-detected if setup.sh was run) ----

# Path to the Dolphin executable. Default matches setup.sh's install location.
DOLPHIN_PATH=./emulator/squashfs-root/usr/bin/dolphin-emu

# Path to Melee 1.02 NTSC ISO.
ISO_PATH=./melee.iso

# Repo root — usually the dir you're running the bot from, no need to change.
# MIMIC_REPO=/root/MIMIC

# Hard per-match wall-clock timeout (seconds). Dolphin is killed after this.
# 15 minutes is generous; typical netplay matches finish in 3-6 min.
MATCH_TIMEOUT_SEC=900
